{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://omegaprotocol.org/schemas/reasoning-chain.schema.json",
  "title": "ReasoningChain",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "nodes",
    "edges",
    "acyclic"
  ],
  "properties": {
    "nodes": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "id",
          "type",
          "statement"
        ],
        "properties": {
          "id": {
            "type": "string"
          },
          "type": {
            "type": "string",
            "enum": [
              "FACT",
              "INFERENCE",
              "ASSUMPTION",
              "UNKNOWN"
            ]
          },
          "statement": {
            "type": "string"
          }
        }
      }
    },
    "edges": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "from",
          "to"
        ],
        "properties": {
          "from": {
            "type": "string"
          },
          "to": {
            "type": "string"
          }
        }
      }
    },
    "acyclic": {
      "type": "boolean"
    },
    "provenance": {
      "type": "array",
      "items": {
        "$ref": "derived-field-provenance.schema.json"
      }
    }
  }
}
