{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://omegaprotocol.org/schemas/dimension-score.schema.json",
  "title": "DimensionScore",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "raw_score",
    "score",
    "confidence",
    "evidence_count",
    "last_updated",
    "availability"
  ],
  "properties": {
    "raw_score": {
      "type": [
        "number",
        "null"
      ]
    },
    "score": {
      "type": [
        "number",
        "null"
      ]
    },
    "confidence": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    },
    "evidence_count": {
      "type": "number"
    },
    "last_updated": {
      "type": "string"
    },
    "availability": {
      "$ref": "data-availability.schema.json"
    }
  }
}
