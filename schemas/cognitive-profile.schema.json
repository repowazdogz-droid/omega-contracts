{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://omegaprotocol.org/schemas/cognitive-profile.schema.json",
  "title": "CognitiveProfile",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "calibration",
    "bias_count",
    "growth_trajectory",
    "consistency",
    "recurring_biases",
    "availability"
  ],
  "properties": {
    "calibration": {
      "type": [
        "number",
        "null"
      ]
    },
    "bias_count": {
      "type": "number"
    },
    "growth_trajectory": {
      "type": "string",
      "enum": [
        "improving",
        "stable",
        "declining",
        "unknown"
      ]
    },
    "consistency": {
      "type": [
        "number",
        "null"
      ]
    },
    "recurring_biases": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "bias_type",
          "frequency",
          "confidence"
        ],
        "properties": {
          "bias_type": {
            "type": "string"
          },
          "frequency": {
            "type": "number"
          },
          "confidence": {
            "type": "number",
            "minimum": 0,
            "maximum": 1
          }
        }
      }
    },
    "availability": {
      "type": "object",
      "additionalProperties": {
        "$ref": "data-availability.schema.json"
      }
    },
    "provenance": {
      "type": "array",
      "items": {
        "$ref": "derived-field-provenance.schema.json"
      }
    }
  }
}
