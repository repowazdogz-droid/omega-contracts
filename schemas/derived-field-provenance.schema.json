{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://omegaprotocol.org/schemas/derived-field-provenance.schema.json",
  "title": "DerivedFieldProvenance",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "field",
    "method",
    "inputs",
    "confidence",
    "input_fingerprint"
  ],
  "properties": {
    "field": {
      "type": "string"
    },
    "method": {
      "type": "string"
    },
    "inputs": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "confidence": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    },
    "input_fingerprint": {
      "type": "string",
      "pattern": "^[a-f0-9]{64}$"
    }
  }
}
