{
  "name": "@omega-protocol/contracts",
  "version": "0.3.0",
  "description": "Canonical interoperability substrate for OMEGA protocol libraries",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./schemas/*": "./schemas/*",
    "./fixtures/*": "./fixtures/*",
    "./package.json": "./package.json"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "omega-contracts-conformance": "dist/cli.js",
    "omega-contracts": "dist/cli.js"
  },
  "files": [
    "dist",
    "schemas",
    "fixtures"
  ],
  "scripts": {
    "build": "tsc && node scripts/postbuild.mjs",
    "test": "vitest run",
    "check": "tsc --noEmit",
    "conformance": "tsx src/cli.ts"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/repowazdogz-droid/omega-contracts.git"
  },
  "homepage": "https://omegaprotocol.org/contracts/",
  "keywords": [
    "omega",
    "governance",
    "ai-safety",
    "interoperability"
  ],
  "author": "Warren Smith",
  "license": "MIT",
  "type": "module",
  "dependencies": {
    "ajv": "^8.20.0",
    "canonicalize": "^3.0.0"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "json-schema-to-typescript": "^15.0.4",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.1.5"
  }
}
